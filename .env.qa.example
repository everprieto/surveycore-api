# QA Environment - Azure App Service + Neon PostgreSQL
# Copy to .env in QA deployment
SECRET_KEY=qa-secret-key-change-in-production-min-32-chars-long-for-hs256
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database — PostgreSQL on Neon (using psycopg v3 driver)
DATABASE_URL=xxx

# CORS — Azure Static Web App frontend URLs
CORS_ORIGINS=https://surveycore-qa.azurewebsites.net,https://happy-smoke-01be95e1e.7.azurestaticapps.net,http://localhost:5173,https://ambitious-water-0fcbaf010.7.azurestaticapps.net

# Microsoft Entra ID SSO
AZURE_TENANT_ID=0a964db6-c0c3-43a8-af0d-bccc2d2bd487
AZURE_CLIENT_ID=4012c112-0db8-4411-85e5-907edceb644e
AZURE_CLIENT_SECRET=your-qa-client-secret-from-azure

AZURE_COMMUNICATION_CONNECTION_STRING=xxx
