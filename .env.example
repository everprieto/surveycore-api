# Copy this file to .env and fill in your values
# cp .env.example .env

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-min-32-chars-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database — PostgreSQL on Neon (using psycopg v3 driver)
# Get your connection string from: https://console.neon.tech → Connection string
# Format: postgresql+psycopg://user:password@host-pooler/database?sslmode=require&channel_binding=require
DATABASE_URL=xxx

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=*

# Microsoft Entra ID SSO (optional — leave empty to disable SSO)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

AZURE_COMMUNICATION_CONNECTION_STRING=xxx
